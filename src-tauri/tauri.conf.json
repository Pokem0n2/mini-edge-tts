{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiniEdgeTTS",
  "identifier": "com.miniedge.tts",
  "version": "1.0.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mini Edge TTS",
        "width": 600,
        "height": 720,
        "resizable": true,
        "center": true,
        "devtools": true
      }
    ]
  }
}
