{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiniEdgeTTS",
  "identifier": "com.miniedge.tts",
  "version": "1.0.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mini Edge TTS",
        "width": 600,
        "height": 720,
        "resizable": true,
        "center": true,
        "devtools": true
      }
    ],
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png", "icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"],
    "resources": {
      "dist/edge_tts_wrapper.exe": "edge_tts_wrapper.exe"
    }
  }
}
